# --- Secrets & credentials (highest priority) ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.*
secrets.*

# --- Local AI agent state ---
# Handoff snapshots may contain work-in-progress context / secrets.
# We ignore all of them BUT keep EXAMPLE.md as a committed reference of the
# §3.2 schema. NOTE: gitignore needs "/*" + a negation here — ignoring the
# directory itself would prevent git from descending into it at all, so the
# negation could not re-include EXAMPLE.md.
.claude/handoffs/*
!.claude/handoffs/EXAMPLE.md
.claude/settings.local.json
.claude/.cache/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# --- Node / TypeScript ---
node_modules/
.next/
out/
.turbo/
.cache/

# --- Misc ---
tmp/
*.tmp
